# `.input` files use TOML syntax.
#
# This reproduces the old `sanity_aw_packet` test as a normal case input.
# The built-in `aw_packet` initializer creates the same large-amplitude
# packet used there: a smooth `phi = psi` superposition of the first three
# modes in each direction, normalized to unit RMS.
#
# Use:
#   python -m rmhdgpu.run examples/aw_packet.input
#   python vis/aw_packet.py examples/aw_packet.input

title = "Qualitative Alfvén-wave packet translation"
output_dir = "outputs"

[grid]
Nx = 32
Ny = 32
Nz = 32

[time]
# The old sanity script advanced to 0.5 Alfven times. With the default
# periodic box and vA = 1, that is t = pi.
tmax = 3.141592653589793
dt_init = 7.0e-4
use_variable_dt = false
t_out_scal = 0.3141592653589793

[backend]
backend = "numpy"

[physics]
vA = 1.0
cs2_over_vA2 = 1.0

[initial_condition]
type = "aw_packet"

[runtime]
progress_output_every = 100

# This run is ideal, so the default zero dissipation is retained.
