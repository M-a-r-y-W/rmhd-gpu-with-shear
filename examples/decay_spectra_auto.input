# `.input` files use TOML syntax.
#
# This is the auto-dissipation companion to `examples/decay_spectra.input`.
# It uses the same low-mode decaying initial condition, but lets the solver
# choose one common perpendicular hyperdissipation coefficient for all evolved
# fields from the fluctuation amplitude near the chosen dissipation scale.
#
# Use:
#   python -m rmhdgpu.run examples/decay_spectra_auto.input
#   python vis/plot_scalars.py examples/outputs/scalar_diagnostics.csv
#   python vis/plot_budget.py examples/outputs/scalar_diagnostics.csv
#   python vis/plot_spectra.py examples/outputs/spectra.csv

title = "Qualitative decaying turbulence spectra (auto dissipation)"
output_dir = "outputs"

[equations]
type = "s09"

[grid]
Nx = 128
Ny = 128
Nz = 128

[time]
tmax = 4.0
dt_max = 2.0e-2
cfl_number = 0.5

[output]
t_out_scal = 0.4
t_out_spec = 0.5
t_out_full = 0.0

[backend]
backend = "scipy_cpu"
fft_workers = 8

[initial_condition]
type = "decaying_low_modes"

# Auto mode picks a single common perpendicular coefficient for all fields.
# The controller measures the total shell energy near
#
#   k_d = kd_fraction * k_perp,max,retained
#
# then estimates a dissipation-scale amplitude u_d and chooses nu_perp so that
#
#   k_d * u_d ~ nu_perp * k_d^(2 n_perp).
#
# The coefficient is only updated every `update_every` steps and smoothed in
# log space, so it should be much less noisy than a raw shell-by-shell estimate.

[dissipation]
mode = "auto"
n_perp = 3
n_par = 1
nu_par = 0.0
kd_fraction = 0.6
shell_half_width = 0.5
update_every = 10
smooth_factor = 0.2
nu_min = 1e-12
nu_max = 1e-2
max_update_factor = 2.0
