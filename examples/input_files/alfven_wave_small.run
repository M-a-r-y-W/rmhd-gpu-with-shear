# `.run` files use TOML syntax.
title = "Small ideal Alfvén wave"
output_dir = "outputs"

[grid]
Nx = 32
Ny = 32
Nz = 32

[time]
tmax = 4
dt_init = 0.005
dt_max = 0.02
t_out_scal = 0.05

[backend]
backend = "numpy"

[initial_condition]
type = "alfven_mode"
k_indices = [1, 1, 1]
amplitude = 1.0
branch = "plus"

[runtime]
progress_output_every = 10

[dissipation.psi]
nu_perp = 0.0
nu_par = 0.0
n_perp = 3
n_par = 3

[dissipation.omega]
nu_perp = 0.0
nu_par = 0.0
n_perp = 3
n_par = 3
